APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM
#LLM_PROVIDER=GEMINI
LLM_PROVIDER=OPENAI
#LLM_MODEL=gemini-flash-lite-latest
LLM_MODEL=gpt-5.4-2026-03-05
LLM_PROVIDER=GEMINI
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

 

# Pipeline
MAX_FILE_SIZE_MB=10
CONTEXT_TEXT_MAX_LENGTH=1000
ENABLE_CONFLICT_GUARDRAIL=true
CONFLICT_POLICY=DIAGRAM_FIRST
INCLUDE_CONFLICT_METADATA=true
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# App
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_INPUT_QUEUE=analysis.requests
RABBITMQ_OUTPUT_QUEUE=analysis.results
RABBITMQ_EXCHANGE=analysis
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_RECONNECT_MAX_DELAY_SECONDS=60
